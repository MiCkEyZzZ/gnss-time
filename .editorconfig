# EditorConfig root
root = true

# Global settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Rust
[*.rs]
indent_style = space
indent_size = 4
tab_width    = 4
max_line_length = 100

# Data formats (JSON/YAML/TOML)
[*.json]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = tab
tab_width = 4

# Makefile
[Makefile]
indent_style = tab
tab_width = 4

# Docker, Kubernetes
[Dockerfile]
indent_style = space
indent_size = 2

[*.{yaml,yml}]
indent_style = space
indent_size = 2

# Config files
[*.{ini,conf,env,properties}]
indent_style = space
indent_size = 2
